APP_NAME="AI Road Trip Backend"
APP_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# --- Maps (pick route + places backends; no Google billing required) ---
# auto: Google route if GOOGLE_MAPS_API_KEY set, else OpenRouteService; places: Google if key else Nominatim
MAPS_ROUTE_PROVIDER=auto
MAPS_PLACES_PROVIDER=auto
GOOGLE_MAPS_API_KEY=""
# Free tier: https://openrouteservice.org/ — server-side directions + geocoding
OPENROUTESERVICE_API_KEY="eyJvcmciOiI1YjNjZTM1OTc4NTExMTAwMDFjZjYyNDgiLCJpZCI6IjAwNWQ0ZGQ4MTI4MjRmOThhZDc3YmJiYzY3MjcwZGZkIiwiaCI6Im11cm11cjY0In0="

# --- Weather ---
# auto: OpenWeatherMap if WEATHER_API_KEY set, else Open-Meteo (no key, free)
WEATHER_PROVIDER=auto
WEATHER_API_KEY="68a7e4b004db54303e83e9a2a12c91aa"

# --- LLM ---
# auto: Gemini if GEMINI_API_KEY set, else OpenAI if OPENAI_API_KEY set
LLM_PROVIDER=auto
GEMINI_API_KEY="AIzaSyAB72oqiawNt1yThXmxzaOw5chtTmdcUl4"
GEMINI_MODEL="gemini-2.5-flash"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL=""

REDIS_URL="redis://localhost:6379/0"
MONGO_URL="mongodb://localhost:27017/ai_trip_planner"
MONGO_DB_NAME="ai_trip_planner"
